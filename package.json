{
  "name": "timomeh.de",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "dev:app": "TZ=UTC next dev",
    "predev:app": "pnpm build:cache-handler --log-level=error",
    "dev:services": "docker compose --profile dev up",
    "dev:logs": "docker compose --profile dev logs -f",
    "build": "next build --experimental-build-mode compile --webpack",
    "prebuild": "pnpm build:cache-handler && pnpm build:migrate",
    "build:cache-handler": "esbuild src/cache-handler.ts --bundle --outfile=dist/cache-handler.js --platform=node --format=cjs",
    "build:migrate": "esbuild scripts/migrate.ts --bundle --outfile=dist/migrate.js --platform=node --format=cjs",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "playwright test",
    "typecheck": "tsc --noEmit",
    "test:ui": "pnpm test --ui",
    "db:generate": "drizzle-kit generate",
    "predb:migrate": "pnpm build:migrate",
    "db:migrate": "node dist/migrate.js",
    "db:studio": "drizzle-kit studio",
    "generate:shiki": "npx shiki-codegen --langs css,docker,dotenv,elixir,fish,git-commit,git-rebase,go,graphql,html,js,json,json5,jsx,markdown,mdx,ruby,shellscript,shellsession,toml,tsx,typescript,yaml --themes one-light,tokyo-night --engine javascript ./src/lib/shiki.bundle.ts"
  },
  "dependencies": {
    "@bprogress/next": "3.2.12",
    "@fancyapps/ui": "6.1.14",
    "@imgproxy/imgproxy-js-core": "1.8.0",
